# GridStatus (free tier - https://gridstatus.io)
GRIDSTATUS_API_KEY=your_key_here

# EIA (free - https://www.eia.gov/opendata/)
EIA_API_KEY=your_key_here

# WattTime (free non-commercial - https://watttime.org)
WATTTIME_USER=your_username_here
WATTTIME_PASSWORD=your_password_here

# NASA POWER (no key needed - completely free)
# NASA_POWER_BASE_URL=https://power.larc.nasa.gov/api

# Ember API (free CC license - https://ember-energy.org/data/api/)
EMBER_API_KEY=your_key_here

# LLM Provider - choose one
# Option A: Ollama local (zero cost, runs on Mac)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Option B: HuggingFace Inference API (free tier)
HF_TOKEN=your_token_here
HF_INFERENCE_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# Option C: Anthropic API (~$1-5/month light use)
ANTHROPIC_API_KEY=your_key_here

# Active LLM provider: ollama | huggingface | anthropic
LLM_PROVIDER=ollama

# Disable anonymous telemetry for Prefect and other tools that respect this standard
DO_NOT_TRACK=1

# Disable Prefect server telemetry to prevent SQLite lock race condition on startup
PREFECT_SERVER_ANALYTICS_ENABLED=false
